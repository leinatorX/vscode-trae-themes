{
  "$schema": "vscode://schemas/color-theme",
  "name": "Dark (Visual Studio)",
  "colors": {
    "checkbox.border": "#6B6B6B",
    "editor.foreground": "#D1D3DB",
    "editor.inactiveSelectionBackground": "#3A3D41",
    "editor.selectionHighlightBackground": "#ADD6FF26",
    "editorBracketMatch.background": "#D5D8E03D",
    "editorBracketMatch.border": "#D5D8E000",
    "list.dropBackground": "#3579ff33",
    "sideBarTitle.foreground": "#BBBBBB",
    "statusBarItem.remoteForeground": "#FFF",
    "statusBarItem.remoteBackground": "#16825D",
    "ports.iconRunningProcessForeground": "#369432",
    "tab.selectedBackground": "#222222",
    "tab.selectedForeground": "#ffffffa0",
    "tab.lastPinnedBorder": "#ccc3",
    "list.activeSelectionIconForeground": "#FFF",
    "terminal.inactiveSelectionBackground": "#3A3D41",
    "widget.border": "#303031",
    "actionBar.toggledBackground": "#383a49",
    "editorCursor.foreground": "#fff",
    "editorLineNumber.foreground": "#979AA4",
    "editorLineNumber.activeForeground": "#E0E3EE",
    "editor.selectionBackground": "#3579FF47",
    "editor.lineHighlightBackground": "#292c34",
    "editorStickyScrollHover.background": "#292c34",
    "editorLink.activeForeground": "#387BFF",
    "textLink.foreground": "#DADDE5",
    "tab.activeBackground": "#E0E2F20d",
    "textLink.activeForeground": "#979AA4",
    "focusBorder": "#00000000",
    "icon.foreground": "#9599A6",
    "titleBar.activeForeground": "#9599A6",
    "foreground": "#D1D3DB",
    "disabledForeground": "#666B75",
    "errorForeground": "#CC4B53",
    "descriptionForeground": "#9599A6",
    "symbolIcon.methodForeground": "#B180D7",
    "editorIndentGuide.background1": "#E0E2F217",
    "editorIndentGuide.activeBackground1": "#E0E2F22E",
    "editorUnnecessaryCode.opacity": "#00000080",
    "diffEditor.insertedLineBackground": "#00A56E47",
    "diffEditor.removedLineBackground": "#D02A2347",
    "diffEditor.insertedTextBackground": "#00A56E47",
    "diffEditor.removedTextBackground": "#D02A2347",
    "editor.background": "#1A1B1D",
    "editor.hoverHighlightBackground": "#264f7840",
    "editor.findMatchHighlightBackground": "#DADDE552",
    "widget.shadow": "#00000029",
    "toolbar.hoverBackground": "#E0E2F20d",
    "toolbar.activeBackground": "#E0E2F214",
    "breadcrumbPicker.background": "#2A2D31",
    "editor.tab.background": "#E0E2F20d",
    "button.foreground": "#000",
    "button.background": "#D1D3DB",
    "button.hoverBackground": "#EDEFF2",
    "inputValidation.errorBorder": "#F65A5A",
    "inputValidation.warningBorder": "#DC8730",
    "input.placeholderForeground": "#9599A6",
    "inputOption.activeBorder": "#E0E2F22E",
    "list.activeSelectionBackground": "#E0E2F214",
    "list.activeSelectionForeground": "#F5F9FE",
    "list.inactiveSelectionBackground": "#E0E2F20d",
    "list.inactiveSelectionForeground": "#F5F9FE",
    "list.hoverBackground": "#E0E2F20d",
    "list.highlightForeground": "#DADDE5",
    "list.errorForeground": "#CC4B53",
    "listFilterWidget.background": "#222427",
    "tree.indentGuidesStroke": "#E0E2F217",
    "tree.inactiveIndentGuidesStroke": "#DDE2E914",
    "menu.border": "#E0E2F217",
    "menu.foreground": "#D1D3DB",
    "menu.background": "#2A2D31",
    "menu.selectionForeground": "#F5F9FE",
    "menu.selectionBackground": "#E0E2F214",
    "menu.separatorBackground": "#E0E2F217",
    "sash.hoverBorder": "#32F08C",
    "progressBar.background": "#387BFF",
    "quickInputList.focusBackground": "#E0E2F214",
    "quickInput.background": "#202123",
    "quickInput.foreground": "#D1D3DB",
    "quickInputTitle.background": "#222427",
    "pickerGroup.foreground": "#D1D3DB",
    "pickerGroup.border": "#E0E2F217",
    "search.resultsInfoForeground": "#9599A6",
    "statusBar.background": "#0000",
    "statusBar.noFolderBackground": "#0000",
    "sideBarSectionHeader.background": "#1A1B1D",
    "sideBarSectionHeader.foreground": "#D1D3DB",
    "sideBarSectionHeader.border": "#E0E2F221",
    "panelTitle.inactiveForeground": "#9599A6",
    "panelTitle.activeForeground": "#F5F9FE",
    "panelSectionHeader.foreground": "#F5F9FE",
    "panelSectionHeader.border": "#E0E2F221",
    "tab.inactiveBackground": "#17191A",
    "activityBarBadge.background": "#387BFF",
    "activityBarBadge.foreground": "#FFFFFF",
    "settings.headerForeground": "#F5F9FE",
    "settings.modifiedItemIndicator": "#DADDE5",
    "settings.headerBorder": "#E0E2F221",
    "settings.dropdownBackground": "#2A2D31",
    "settings.dropdownBorder": "#E0E2F217",
    "debugToolBar.background": "#222427",
    "debugIcon.breakpointForeground": "#F65A5A",
    "titleBar.inactiveBackground": "#222427",
    "titleBar.activeBackground": "#222427",
    "notifications.background": "#2A2D31",
    "activityBar.inactiveForeground": "#9599A6",
    "activityBar.foreground": "#F5F9FE",
    "activityBar.background": "#222427",
    "tab.inactiveForeground": "#9599A6",
    "tab.unfocusedActiveForeground": "#D1D3DB",
    "sideBar.background": "#1A1B1D",
    "notificationsErrorIcon.foreground": "#F65A5A",
    "notificationsInfoIcon.foreground": "#387BFF",
    "notificationsWarningIcon.foreground": "#DC8730",
    "editorBracketPairGuide.background1": "#E0E2F217",
    "editorBracketPairGuide.background2": "#E0E2F217",
    "editorBracketPairGuide.background3": "#E0E2F217",
    "editorBracketPairGuide.background4": "#E0E2F217",
    "editorBracketPairGuide.background5": "#E0E2F217",
    "editorBracketPairGuide.background6": "#E0E2F217",
    "tab.border": "#E0E2F217",
    "editorGroupHeader.tabsBackground": "#17191A",
    "tab.activeBorderTop": "#FFFFFF",
    "editorGroupHeader.tabsBorder": "#E0E2F217",
    "tab.activeBorder": "#1A1B1D",
    "button.separator": "#0D0E0F2E",
    "input.background": "#E0E2F208",
    "tab.activeForeground": "#F5F9FE"
  },
  "tokenColors": [
    {
      "scope": [
        "meta.embedded",
        "source.groovy.embedded",
        "string meta.image.inline.markdown",
        "variable.legacy.builtin.python"
      ],
      "settings": { "foreground": "#82D99F" }
    },
    { "scope": "emphasis", "settings": { "fontStyle": "italic" } },
    { "scope": "strong", "settings": { "fontStyle": "bold" } },
    { "scope": "header", "settings": { "foreground": "#569cd6" } },
    { "scope": "comment", "settings": { "foreground": "#737780" } },
    { "scope": "constant.language", "settings": { "foreground": "#80BBFF" } },
    {
      "scope": [
        "constant.numeric",
        "variable.other.enummember",
        "keyword.operator.plus.exponent",
        "keyword.operator.minus.exponent"
      ],
      "settings": { "foreground": "#F48CCA" }
    },
    { "scope": "constant.regexp", "settings": { "foreground": "#82D99F" } },
    { "scope": "entity.name.tag", "settings": { "foreground": "#F2858C" } },
    {
      "scope": ["entity.name.tag.css", "entity.name.tag.less"],
      "settings": { "foreground": "#DED47E" }
    },
    { "scope": "entity.other.attribute-name", "settings": { "foreground": "#DED47E" } },
    {
      "scope": [
        "entity.other.attribute-name.class.css",
        "source.css entity.other.attribute-name.class",
        "entity.other.attribute-name.id.css",
        "entity.other.attribute-name.parent-selector.css",
        "entity.other.attribute-name.parent.less",
        "source.css entity.other.attribute-name.pseudo-class",
        "entity.other.attribute-name.pseudo-element.css",
        "source.css.less entity.other.attribute-name.id",
        "entity.other.attribute-name.scss"
      ],
      "settings": { "foreground": "#DED47E" }
    },
    { "scope": "invalid", "settings": { "foreground": "#CC4B53" } },
    { "scope": "markup.underline", "settings": { "fontStyle": "underline" } },
    { "scope": "markup.bold", "settings": { "fontStyle": "bold", "foreground": "#D5D8E0" } },
    { "scope": "markup.heading", "settings": { "fontStyle": "bold", "foreground": "#80BBFF" } },
    { "scope": "markup.italic", "settings": { "fontStyle": "italic" } },
    { "scope": "markup.strikethrough", "settings": { "fontStyle": "strikethrough" } },
    { "scope": "markup.inserted", "settings": { "foreground": "#66CCAA" } },
    { "scope": "markup.deleted", "settings": { "foreground": "#F2858C" } },
    { "scope": "markup.changed", "settings": { "foreground": "#80BBFF" } },
    {
      "scope": "punctuation.definition.quote.begin.markdown",
      "settings": { "foreground": "#737780" }
    },
    {
      "scope": "punctuation.definition.list.begin.markdown",
      "settings": { "foreground": "#F2858C" }
    },
    { "scope": "markup.inline.raw", "settings": { "foreground": "#82D99F" } },
    {
      "name": "brackets of XML/HTML tags",
      "scope": "punctuation.definition.tag",
      "settings": { "foreground": "#D5D8E0" }
    },
    {
      "scope": ["meta.preprocessor", "entity.name.function.preprocessor"],
      "settings": { "foreground": "#80BBFF" }
    },
    { "scope": "meta.preprocessor.string", "settings": { "foreground": "#82D99F" } },
    { "scope": "meta.preprocessor.numeric", "settings": { "foreground": "#80BBFF" } },
    { "scope": "meta.structure.dictionary.key.python", "settings": { "foreground": "#82D99F" } },
    { "scope": "meta.diff.header", "settings": { "foreground": "#D5D8E0" } },
    { "scope": "storage", "settings": { "foreground": "#B38CFF" } },
    { "scope": "storage.type", "settings": { "foreground": "#B38CFF" } },
    {
      "scope": ["storage.modifier", "keyword.operator.noexcept"],
      "settings": { "foreground": "#B38CFF" }
    },
    { "scope": ["string", "meta.embedded.assembly"], "settings": { "foreground": "#82D99F" } },
    { "scope": "string.tag", "settings": { "foreground": "#82D99F" } },
    { "scope": "string.value", "settings": { "foreground": "#82D99F" } },
    { "scope": "string.regexp", "settings": { "foreground": "#82D99F" } },
    {
      "name": "String interpolation",
      "scope": [
        "punctuation.definition.template-expression.begin",
        "punctuation.definition.template-expression.end",
        "punctuation.section.embedded"
      ],
      "settings": { "foreground": "#F2858C" }
    },
    {
      "name": "Reset JavaScript string interpolation expression",
      "scope": ["meta.template.expression"],
      "settings": { "foreground": "#B38CFF" }
    },
    {
      "scope": [
        "support.type.vendored.property-name",
        "support.type.property-name",
        "source.css variable",
        "source.coffee.embedded"
      ],
      "settings": { "foreground": "#D5D8E0" }
    },
    { "scope": "keyword", "settings": { "foreground": "#B38CFF" } },
    { "scope": "keyword.control", "settings": { "foreground": "#B38CFF" } },
    { "scope": "keyword.operator", "settings": { "foreground": "#D5D8E0" } },
    {
      "scope": [
        "keyword.operator.new",
        "keyword.operator.expression",
        "keyword.operator.cast",
        "keyword.operator.sizeof",
        "keyword.operator.alignof",
        "keyword.operator.typeid",
        "keyword.operator.alignas",
        "keyword.operator.instanceof",
        "keyword.operator.logical.python",
        "keyword.operator.wordlike"
      ],
      "settings": { "foreground": "#B38CFF" }
    },
    { "scope": "keyword.other.unit", "settings": { "foreground": "#F48CCA" } },
    {
      "scope": ["punctuation.section.embedded.begin.php", "punctuation.section.embedded.end.php"],
      "settings": { "foreground": "#80BBFF" }
    },
    { "scope": "support.function.git-rebase", "settings": { "foreground": "#9cdcfe" } },
    { "scope": "constant.sha.git-rebase", "settings": { "foreground": "#b5cea8" } },
    {
      "name": "coloring of the Java import and package identifiers",
      "scope": [
        "storage.modifier.import.java",
        "variable.language.wildcard.java",
        "storage.modifier.package.java"
      ],
      "settings": { "foreground": "#D5D8E0" }
    },
    { "name": "this.self", "scope": "variable.language", "settings": { "foreground": "#DED47E" } },
    { "scope": "log.error", "settings": { "foreground": "#CC4B53" } },
    { "scope": "log.warning", "settings": { "foreground": "#EB9B61" } }
  ],
  "semanticHighlighting": true,
  "semanticTokenColors": {
    "newOperator": "#D5D8E0",
    "stringLiteral": "#82D99F",
    "customLiteral": "#D5D8E0",
    "numberLiteral": "#F48CCA"
  }
}
