  "tokenColors": [
    {
      "scope": [
        "meta.embedded",
        "source.groovy.embedded",
        "string meta.image.inline.markdown",
        "variable.legacy.builtin.python"
      ],
      "settings": {
        "foreground": "#82D99F"
      }
    },
    {
      "scope": "emphasis",
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": "strong",
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "scope": "header",
      "settings": {
        "foreground": "#569cd6"
      }
    },
    {
      "scope": "comment",
      "settings": {
        "foreground": "#737780"
      }
    },
    {
      "scope": "constant.language",
      "settings": {
        "foreground": "#80BBFF"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "variable.other.enummember",
        "keyword.operator.plus.exponent",
        "keyword.operator.minus.exponent"
      ],
      "settings": {
        "foreground": "#F48CCA"
      }
    },
    {
      "scope": "constant.regexp",
      "settings": {
        "foreground": "#82D99F"
      }
